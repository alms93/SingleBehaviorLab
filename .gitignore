# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
*.egg-info/
dist/
build/

# Vendored upstream packages: exclude compiled artifacts only
third_party/**/__pycache__/
third_party/**/*.egg-info/

# SAM2 checkpoints — large binary files, auto-downloaded by the app on first use.
third_party/sam2_backend/sam2/checkpoints/*.pt

# VideoPrism backbone (auto-downloaded on first use)
models/videoprism_backbone/

# User experiment data (created at runtime)
experiments/*/data/
experiments/*/models/behavior_heads/*.pt

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
